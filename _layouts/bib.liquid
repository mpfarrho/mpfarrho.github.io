---
---
{% comment %}
  Per-entry template for jekyll-scholar's {% bibliography %} (set via
  scholar.bibliography_template: bib). Emits the research mockup's .pub markup.
  Pills link to real bib fields (arxiv / html / code); the "bib" pill toggles the
  BibTeX block (toggle JS lives in _includes/head.liquid). All authors are
  listed by surname only, with no truncation.
{% endcomment %}
{%- capture venue -%}
{%- if entry.type == 'article' -%}
{{ entry.journal }}{% if entry.volume %} {{ entry.volume }}{% if entry.number %}({{ entry.number }}){% endif %}{% endif %}{% if entry.pages %}, {{ entry.pages | replace: '--', '–' }}{% endif %}, {{ entry.year }}
{%- elsif entry.type == 'incollection' -%}
{{ entry.booktitle }}{% if entry.chapter %}, ch. {{ entry.chapter }}{% endif %}, {{ entry.year }}
{%- else -%}
{{ entry.note }}{% if entry.year %} &middot; {{ entry.year }}{% endif %}
{%- endif -%}
{%- endcapture -%}
<div class="pub" id="{{ entry.key }}">
  <span class="title">{{ entry.title }}</span>
  <div class="authors">
    {%- for author in entry.author_array -%}
      {% unless forloop.first %}, {% endunless -%}
      {{- author.last }}
    {%- endfor -%}
  </div>
  <div class="meta">
    <span class="kind">{{ venue | strip }}</span>
    {%- if entry.type == 'unpublished' -%}
      {%- if entry.arxiv -%}
        <a class="pill" href="http://arxiv.org/abs/{{ entry.arxiv }}">wp</a>
      {%- elsif entry.html -%}
        <a class="pill" href="{{ entry.html }}">wp</a>
      {%- endif -%}
    {%- elsif entry.type == 'incollection' -%}
      {%- if entry.html -%}
        <a class="pill" href="{{ entry.html }}">chapter</a>
      {%- endif -%}
    {%- elsif entry.type == 'misc' -%}
      {%- if entry.html -%}
        <a class="pill" href="{{ entry.html }}">link</a>
      {%- endif -%}
    {%- else -%}
      {%- if entry.html -%}
        <a class="pill" href="{{ entry.html }}">doi</a>
      {%- endif -%}
      {%- if entry.arxiv -%}
        <a class="pill" href="http://arxiv.org/abs/{{ entry.arxiv }}">wp</a>
      {%- endif -%}
      {%- if entry.code -%}
        <a class="pill" href="{{ entry.code }}">code</a>
      {%- endif -%}
    {%- endif -%}
    {%- if entry.bibtex_show -%}
      <a class="pill bib-toggle" role="button" tabindex="0" aria-expanded="false">bib</a>
    {%- endif -%}
  </div>
  {%- if entry.bibtex_show -%}
    <div class="pub-bibtex" hidden>
      <button class="bib-copy" type="button" aria-label="Copy BibTeX to clipboard">copy</button>
      <pre>{{ entry.bibtex | hideCustomBibtex | escape }}</pre>
    </div>
  {%- endif -%}
</div>
