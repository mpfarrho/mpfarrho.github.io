{% comment %}
  Home layout — standalone document reproducing /mockups/index.html.
  The hero eyebrow comes from page.subtitle, the bio from the page content
  (_pages/about.md), the photo from page.profile.image, and the profile-link
  strip from _data/socials.yml. The CV / Activities / Education / Honors /
  Grants / Presentations / Teaching sections and the sticky TOC are rendered
  from _data/cv.yml. Section ids must match the mockup verbatim for the
  scroll-spy in head.liquid.
{% endcomment %}
{% capture author_name %}{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}{% endcapture %}
<!doctype html>
<html lang="{{ site.lang | default: 'en' }}" data-theme="light">
  <head>
    {% include head.liquid %}
  </head>
  <body class="home">
    {% include header.liquid %}

    <main>
      <section class="hero wrap">
        <div class="hero-grid">
          <div class="hero-text">
            <p class="eyebrow">{{ page.subtitle }}</p>
            {% if page.headline %}
              <h1>{{ page.headline }}</h1>
            {% endif %}
            {{ content }}
          </div>
          <div class="hero-photo">
            <div class="frame">
              <img src="{{ page.profile.image | default: 'prof_pic.jpg' | prepend: '/assets/img/' | relative_url }}" alt="{{ author_name }}">
            </div>
            <nav class="profiles" aria-label="Academic profiles">
              {% if site.data.socials.scholar_userid %}
                <a href="https://scholar.google.at/citations?user={{ site.data.socials.scholar_userid }}">Google Scholar</a>
              {% endif %}
              {% if site.data.socials.repec %}
                <a href="{{ site.data.socials.repec.url }}">{{ site.data.socials.repec.title }}</a>
              {% endif %}
              {% if site.data.socials.orcid_id %}
                <a href="https://orcid.org/{{ site.data.socials.orcid_id }}">ORCID</a>
              {% endif %}
              {% if site.data.socials.github_username %}
                <a href="https://github.com/{{ site.data.socials.github_username }}">GitHub</a>
              {% endif %}
              {% if site.data.socials.linkedin_username %}
                <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}/">LinkedIn</a>
              {% endif %}
            </nav>
          </div>
        </div>
      </section>

      <div class="wrap layout">
        <aside class="toc">
          <nav aria-label="Sections">
            <ul>
              {% for s in site.data.cv.sections %}
                <li>
                  <a href="#{{ s.id }}">{{ s.nav }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </aside>

        <div class="content">
          {% for s in site.data.cv.sections %}
            <section class="block" id="{{ s.id }}">
              <h2>{{ s.title }}</h2>
              <div class="block-rule"></div>
              {% for b in s.blocks %}
                {% case b.type %}
                  {% when 'entry' %}
                    <div class="entry">
                      <div class="entry-main">
                        <span class="role">{{ b.role }}</span><span class="org">{{ b.org }}</span>
                      </div>
                      <div class="entry-date">{{ b.date }}</div>
                    </div>
                  {% when 'sub' %}
                    <div class="sub">{{ b.text }}</div>
                  {% when 'deflist' %}
                    <dl class="deflist">
                      {% for r in b.rows %}
                        <div class="row">
                          <div class="label">{{ r.label }}</div>
                          <div class="val">{{ r.val }}</div>
                        </div>
                      {% endfor %}
                    </dl>
                  {% when 'personal' %}
                    <div class="personal">
                      <p>
                        <span class="k">{{ b.k }}</span>{{ b.text }}
                      </p>
                    </div>
                {% endcase %}
              {% endfor %}
            </section>
          {% endfor %}
        </div>
      </div>
    </main>

    {% include footer.liquid %}
  </body>
</html>
