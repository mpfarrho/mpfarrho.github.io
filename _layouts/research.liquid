{% comment %}
  Research layout — standalone document reproducing /mockups/research.html.
  The eyebrow comes from page.title and the intro from the page content
  (_pages/publications.md). The TOC and publication sections are driven by the
  page's `sections` front matter (id / title / query); each section renders
  _bibliography/papers.bib via jekyll-scholar (the --query argument is Liquid-
  interpolated), and each entry is templated by _layouts/bib.liquid into the
  .pub markup. Section ids feed the scroll-spy in head.liquid.
{% endcomment %}
<!doctype html>
<html lang="{{ site.lang | default: 'en' }}" data-theme="light">
  <head>
    {% include head.liquid %}
  </head>
  <body class="research">
    {% include header.liquid %}

    <main>
      <section class="page-head wrap">
        <p class="eyebrow">{{ page.title }}</p>
        {{ content }}
      </section>

      <div class="wrap layout">
        <aside class="toc">
          <nav aria-label="Sections">
            <ul>
              {% for s in page.sections %}
                <li>
                  <a href="#{{ s.id }}">{{ s.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </aside>

        <div class="content">
          {% for s in page.sections %}
            <section class="block" id="{{ s.id }}">
              <h2>{{ s.title }}</h2>
              <div class="block-rule"></div>
              {% bibliography --query {{ s.query }} %}
            </section>
          {% endfor %}
        </div>
      </div>
    </main>

    {% include footer.liquid %}
  </body>
</html>
