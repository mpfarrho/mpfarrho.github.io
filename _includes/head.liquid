<!-- Metadata, OpenGraph and Schema.org -->
{% include metadata.liquid %}

<!-- Security: Content Security Policy -->
<!-- Permissive CSP suitable for academic websites. Allows external images, videos, and common embed services. -->
<!-- To customize for your needs, see: https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP -->
<meta
  http-equiv="Content-Security-Policy"
  content="default-src 'self'; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; media-src 'self' https:; frame-src 'self' https:; connect-src 'self' https:;"
>

<!-- Bootstrap & MDB -->
<link rel="stylesheet" href="{{ '/assets/css/bootstrap.min.css' | relative_url | bust_file_cache }}">
<link
  rel="stylesheet"
  href="{{ site.third_party_libraries.mdb.url.css }}"
  integrity="{{ site.third_party_libraries.mdb.integrity.css }}"
  crossorigin="anonymous"
>

{% if page.pretty_table %}
  <!-- Bootstrap Table -->
  <link
    defer
    rel="stylesheet"
    href="{{ site.third_party_libraries.bootstrap-table.url.css }}"
    integrity="{{ site.third_party_libraries.bootstrap-table.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

<!-- Fonts & Icons -->
<link defer rel="stylesheet" href="{{ '/assets/css/academicons.min.css' | relative_url | bust_file_cache }}">
<link defer rel="stylesheet" href="{{ '/assets/css/scholar-icons.css' | relative_url | bust_file_cache }}">
<!--
  Fonts: EB Garamond + IBM Plex Sans + IBM Plex Mono. Loaded once here via the
  mockup's preconnect + stylesheet; al-folio's own deferred Google Fonts link
  was removed so the families are not requested twice.
-->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="{{ site.third_party_libraries.google_fonts.url.fonts }}" rel="stylesheet">

<!-- Code Syntax Highlighting -->
<link
  defer
  rel="stylesheet"
  href="{{ '/assets/css/jekyll-pygments-themes-github.css' | relative_url | bust_file_cache }}"
  media=""
  id="highlight_theme_light"
>

{% if page.toc and page.toc.sidebar %}
  <!-- Sidebar Table of Contents -->
  <link defer href="{{ '/assets/css/bootstrap-toc.min.css' | relative_url | bust_file_cache }}" rel="stylesheet">
{% endif %}

<!-- Styles -->

{% if page.pseudocode %}
  <!-- pseudocode -->
  <link
    defer
    rel="stylesheet"
    href="{{ site.third_party_libraries.pseudocode.url.css }}"
    integrity="{{ site.third_party_libraries.pseudocode.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

{% if site.icon.size <= 4 %}
  <link
    rel="shortcut icon"
    href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>{{ site.icon }}</text></svg>"
  >
{% elsif site.icon != blank %}
  <link rel="shortcut icon" href="{{ site.icon | prepend: '/assets/img/' | relative_url | bust_file_cache}}">
{% endif %}
<link rel="stylesheet" href="{{ '/assets/css/main.css' | relative_url | bust_css_cache }}">
<link rel="canonical" href="{{ page.url | replace:'index.html','' | absolute_url }}">

<!--
  Theme: tri-state toggle (the mockup's script, extended). The stored choice is
  one of 'system' | 'light' | 'dark'; the default (nothing stored) is 'system',
  which follows the browser/OS color-scheme setting and tracks it live. The
  header button cycles system -> light -> dark -> system. The theme is resolved
  and set before first paint (no FOUC). This replaces al-folio's theme.js +
  toggle entirely; the localStorage key stays "theme" so any previously stored
  light/dark preference keeps working.
-->
<!--
  Browser-chrome tint (mobile address bar, Safari); kept in sync with the
  effective theme by setTheme() in the script below
-->
<meta name="theme-color" content="#ffffff">
<script>
  (function () {
    var root = document.documentElement;
    var mql = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;

    function systemTheme() {
      return mql && mql.matches ? 'dark' : 'light';
    }
    // state = the user's choice ('system' | 'light' | 'dark');
    // effective() maps it to the painted theme ('light' | 'dark').
    function effective(s) {
      return s === 'light' || s === 'dark' ? s : systemTheme();
    }
    // paints the theme and keeps the browser-chrome tint in step
    // (colors mirror --bg in _sass/_custom.scss)
    function setTheme(t) {
      root.setAttribute('data-theme', t);
      var tc = document.querySelector('meta[name="theme-color"]');
      if (tc) tc.setAttribute('content', t === 'dark' ? '#0f141a' : '#ffffff');
    }

    var state = 'system';
    try {
      var saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark' || saved === 'system') state = saved;
    } catch (e) {}
    setTheme(effective(state));

    // Shim: al-folio's common.js still calls determineComputedTheme(); keep it defined.
    window.determineComputedTheme =
      window.determineComputedTheme ||
      function () {
        return root.getAttribute('data-theme') || 'light';
      };

    var sun =
      '<circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.5M12 19v2.5M4.6 4.6l1.8 1.8M17.6 17.6l1.8 1.8M2.5 12H5M19 12h2.5M4.6 19.4l1.8-1.8M17.6 6.4l1.8-1.8"/>';
    var moon = '<path d="M20 14.5A8 8 0 0 1 9.5 4 7 7 0 1 0 20 14.5Z"/>';
    var auto = '<circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 0 1 0 18Z" fill="currentColor" stroke="none"/>';
    function paintIcon() {
      var icon = document.getElementById('themeIcon');
      if (icon) icon.innerHTML = state === 'system' ? auto : state === 'dark' ? moon : sun;
      var btn = document.getElementById('themeToggle');
      if (btn) {
        var label = state === 'system' ? 'System' : state === 'dark' ? 'Dark' : 'Light';
        btn.title = 'Theme: ' + label;
        btn.setAttribute('aria-label', 'Theme: ' + label + ' (click to change)');
      }
    }

    // In 'system' mode, follow live OS color-scheme changes.
    if (mql) {
      var onChange = function () {
        if (state === 'system') setTheme(systemTheme());
      };
      if (mql.addEventListener) mql.addEventListener('change', onChange);
      else if (mql.addListener) mql.addListener(onChange);
    }

    function init() {
      paintIcon();
      var btn = document.getElementById('themeToggle');
      if (btn) {
        btn.addEventListener('click', function () {
          state = state === 'system' ? 'light' : state === 'light' ? 'dark' : 'system';
          setTheme(effective(state));
          try {
            localStorage.setItem('theme', state);
          } catch (e) {}
          paintIcon();
        });
      }
      // research/project pages: the "bib" pill toggles its BibTeX block, the
      // "abstract" pill (project page) its abstract box
      document.querySelectorAll('.bib-toggle, .abs-toggle').forEach(function (t) {
        t.addEventListener('click', function () {
          var pub = t.closest('.pub');
          var box = pub && pub.querySelector(t.classList.contains('abs-toggle') ? '.pub-abstract' : '.pub-bibtex');
          if (!box) return;
          var willOpen = box.hasAttribute('hidden');
          if (willOpen) {
            box.removeAttribute('hidden');
          } else {
            box.setAttribute('hidden', '');
          }
          t.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      });
      // one-click copy inside the BibTeX block
      document.querySelectorAll('.bib-copy').forEach(function (b) {
        b.addEventListener('click', function () {
          var pre = b.closest('.pub-bibtex').querySelector('pre');
          if (!pre || !navigator.clipboard) return;
          navigator.clipboard.writeText(pre.textContent).then(function () {
            b.textContent = 'copied';
            setTimeout(function () {
              b.textContent = 'copy';
            }, 1500);
          });
        });
      });
      var links = Array.prototype.slice.call(document.querySelectorAll('.toc a'));
      if (!links.length) return;
      var map = {};
      links.forEach(function (a) {
        map[a.getAttribute('href').slice(1)] = a;
      });
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) {
              links.forEach(function (a) {
                a.classList.remove('active');
              });
              var a = map[en.target.id];
              if (a) a.classList.add('active');
            }
          });
        },
        { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
      );
      document.querySelectorAll('section.block').forEach(function (s) {
        obs.observe(s);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% if page.map %}
  <!-- GeoJSON support via Leaflet -->
  <link
    defer
    rel="stylesheet"
    href="{{ site.third_party_libraries.leaflet.url.css }}"
    integrity="{{ site.third_party_libraries.leaflet.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

{% if page.code_diff %}
  <!-- diff2html -->
  <link
    defer
    rel="stylesheet"
    href="{{ site.third_party_libraries.highlightjs.url.css.light }}"
    integrity="{{ site.third_party_libraries.highlightjs.integrity.css.light }}"
    crossorigin="anonymous"
    media="screen and (prefers-color-scheme: light)"
  >
  <link
    defer
    rel="stylesheet"
    href="{{ site.third_party_libraries.highlightjs.url.css.dark }}"
    integrity="{{ site.third_party_libraries.highlightjs.integrity.css.dark }}"
    crossorigin="anonymous"
    media="screen and (prefers-color-scheme: dark)"
  >
  <link
    defer
    rel="stylesheet"
    href="{{ site.third_party_libraries.diff2html.url.css }}"
    integrity="{{ site.third_party_libraries.diff2html.integrity.css }}"
    crossorigin="anonymous"
  >
{% endif %}

