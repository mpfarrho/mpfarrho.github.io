{% comment %}
  Site header — pixel reproduction of the sticky translucent header in
  /mockups (index.html / research.html). The active-page underline is driven by
  the current page URL. Email + GitHub icons and the theme toggle button are
  inline SVG (no Font Awesome). The toggle is wired by the script in head.liquid.
{% endcomment %}
{% assign u = page.url %}
<header class="site-header">
  <div class="wrap header-inner">
    <a class="wordmark" href="{{ '/' | relative_url }}" aria-label="Michael Pfarrhofer"
      ><span class="wm-full">Michael Pfarrhofer</span><span class="wm-mono">MP</span></a
    >
    <nav class="nav" aria-label="Primary">
      <span class="nav-links">
        <a
          href="{{ '/' | relative_url }}"
          {% if u == '/' %}
            aria-current="page"
          {% endif %}
          >Home</a
        >
        <a
          href="{{ '/research/' | relative_url }}"
          {% if u contains '/research' %}
            aria-current="page"
          {% endif %}
          >Research</a
        >
      </span>
      <span class="nav-icons">
        <a href="mailto:mpfarrho@gmail.com" aria-label="Email" title="Email">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
            <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
          </svg>
        </a>
        <a href="https://github.com/mpfarrho" aria-label="GitHub" title="GitHub">
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/>
          </svg>
        </a>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" title="Toggle theme">
          <svg class="icon" id="themeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"></svg>
        </button>
      </span>
    </nav>
  </div>
</header>
